{
  "name": "scoring-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "relay",
    "bridge",
    "packages/db"
  ],
  "scripts": {
    "dev:relay": "npm run dev --workspace=relay",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build:relay": "npm run build --workspace=relay",
    "build:frontend": "npm run build --workspace=frontend",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "test": "npm run test --workspaces --if-present",
    "postinstall": "node scripts/patch-postcss-cve-2026-41305.js"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    },
    "ws": ">=8.20.1",
    "qs": ">=6.15.2"
  },
  "allowScripts": {
    "@prisma/client@6.19.3": true,
    "@prisma/engines@6.19.3": true,
    "prisma@6.19.3": true
  }
}
