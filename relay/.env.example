PORT=4000

# Legacy/dev-only fallback secrets — only used when DATABASE_URL is unset
# (local dev, tests). Once DATABASE_URL is set, the relay requires real
# per-org bridge tokens and signed control JWTs instead (see src/auth.ts).
BRIDGE_SECRET=change-this-to-a-long-random-string
CONTROL_SECRET=change-this-to-a-different-long-random-string

# Postgres connection string (Neon) for tenant-scoped match persistence
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Must match the frontend's AUTH_SECRET exactly — used to verify
# control-panel tokens minted by the frontend's /api/control-token route.
AUTH_SECRET=change-this-to-a-long-random-string

# Optional. Upstash Redis (or any Redis) connection string, used for the
# Socket.io cross-instance adapter and the clock tick-lock so multiple relay
# instances can run behind a load balancer (SA-62/SA-19). Omitting this
# preserves today's single-instance, in-memory-only behavior.
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379

# Optional. Cloudflare R2 (S3-compatible) + CDN for logo/sound uploads
# (SA-64/SA-27). All five must be set together to enable it — omitting any
# one falls back to today's local-disk UPLOAD_DIR behavior, so dev/self-hosted
# and the Jest suite are unaffected.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=scorehub-uploads
R2_PUBLIC_URL=https://cdn.scorehub.app
