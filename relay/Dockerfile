# Build context is the repo root (see railway.toml), not relay/ — relay
# depends on the internal @scorehub/db workspace package, which only exists
# via the root npm workspace install, never the public registry. A
# relay-only build context can't see packages/db at all, which is why every
# deploy since the multi-tenant Postgres phase failed with a 404 on
# "@scorehub/db" from npm install.

# ── Build stage ──────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
COPY scripts ./scripts
COPY relay/package.json ./relay/
COPY packages/db/package.json ./packages/db/
COPY frontend/package.json ./frontend/
COPY bridge/package.json ./bridge/
RUN npm ci

COPY packages/db ./packages/db
RUN npm run build --workspace=@scorehub/db

COPY relay/tsconfig.json ./relay/
COPY relay/src ./relay/src
RUN npm run build --workspace=scorehub-relay

# ── Runtime stage ─────────────────────────────────────────────────────────────
# Reuses the builder's node_modules wholesale rather than a fresh
# `npm install --omit=dev` — @scorehub/db's generated Prisma client (from
# `prisma generate`) lives inside node_modules and isn't regenerated by a
# plain install, since the schema lives at a non-default path.
FROM node:20-alpine
WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package*.json ./
COPY --from=builder /app/packages/db ./packages/db
COPY --from=builder /app/relay/package.json ./relay/
COPY --from=builder /app/relay/dist ./relay/dist
# npm's hoisting can't fully dedupe across workspaces with conflicting
# transitive deps, so some packages (e.g. socket.io) land in a workspace's
# own nested node_modules instead of the root — both must be copied.
COPY --from=builder /app/relay/node_modules ./relay/node_modules
COPY --from=builder /app/packages/db/node_modules ./packages/db/node_modules

RUN mkdir -p /app/relay/uploads && \
    addgroup -S appgroup && adduser -S appuser -G appgroup && \
    chown -R appuser:appgroup /app/relay/uploads

USER appuser
WORKDIR /app/relay

EXPOSE 4000
ENV NODE_ENV=production

CMD ["node", "dist/index.js"]
