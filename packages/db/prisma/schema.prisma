generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tenant / billing boundary. One paying customer.
model Account {
  id                   String   @id @default(uuid())
  name                 String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  plan                 String   @default("free")
  createdAt            DateTime @default(now())

  orgs Org[]
}

// Tracks processed Stripe webhook event IDs so a Stripe-initiated retry of an
// already-handled event can't double-apply a plan change.
model StripeEvent {
  id          String   @id
  processedAt DateTime @default(now())
}

enum OrgType {
  FEDERATION
  REGION
  CLUB
  TEAM
}

// Hierarchical unit within an account, e.g. a federation with regional/club/team
// sub-orgs. Most accounts will have exactly one Org; federation customers nest them.
model Org {
  id          String   @id @default(uuid())
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id])
  parentOrgId String?
  parent      Org?     @relation("OrgHierarchy", fields: [parentOrgId], references: [id])
  children    Org[]    @relation("OrgHierarchy")
  orgType     OrgType  @default(CLUB)
  name        String
  createdAt   DateTime @default(now())

  matches     Match[]
  memberships Membership[]
  tokens      ScopedToken[]

  @@index([accountId])
  @@index([parentOrgId])
}

enum MatchStatus {
  LIVE
  ENDED
}

// Replaces the relay's in-memory singleton match state. `state` mirrors the
// relay's MatchState shape verbatim (kept as Json so the relay's TypeScript
// type stays the single source of truth for the score-state schema).
model Match {
  id        String      @id @default(uuid())
  orgId     String
  org       Org         @relation(fields: [orgId], references: [id])
  state     Json
  status    MatchStatus @default(LIVE)
  createdAt DateTime    @default(now())
  endedAt   DateTime?

  @@index([orgId])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())

  memberships Membership[]
}

enum Role {
  ADMIN
  OPERATOR
  VIEWER
}

// RBAC scaffolding: which orgs a user belongs to and what they can do there.
model Membership {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orgId     String
  org       Org      @relation(fields: [orgId], references: [id])
  role      Role     @default(VIEWER)
  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

enum ScopedTokenType {
  BRIDGE
}

// Per-org credential for headless devices (the bridge) that can't do an
// interactive NextAuth login. Only the hash is stored; the plaintext is
// shown once at creation time.
model ScopedToken {
  id         String          @id @default(uuid())
  orgId      String
  org        Org             @relation(fields: [orgId], references: [id])
  type       ScopedTokenType
  tokenHash  String          @unique
  label      String?
  createdAt  DateTime        @default(now())
  revokedAt  DateTime?

  @@index([orgId])
}
