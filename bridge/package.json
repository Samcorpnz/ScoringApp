{
  "name": "scorehub-bridge",
  "version": "1.0.0",
  "description": "Venue-side serial bridge — reads Saturn console, pushes to cloud relay",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && cp -r src/ui/public dist/ui/public",
    "start": "node dist/index.js",
    "test": "jest"
  },
  "dependencies": {
    "express": "^5.2.1",
    "node-fetch": "^3.3.2",
