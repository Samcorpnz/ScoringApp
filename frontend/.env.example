NEXT_PUBLIC_RELAY_URL=https://your-relay.fly.dev

# Postgres connection string (Neon) — accounts, orgs, matches
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth — generate with: openssl rand -hex 32
# Must match the relay's AUTH_SECRET exactly — the relay verifies
# control-panel tokens minted by /api/control-token with this same secret.
AUTH_SECRET=change-this-to-a-long-random-string
NEXTAUTH_URL=https://app.scorehub.co.nz

# Users now sign up via /signup — no more AUTH_USERS env var.

# Stripe billing (SA-23) — secret key from the Stripe dashboard, webhook
# signing secret from `stripe listen` (dev) or the dashboard's webhook
# endpoint config (prod), and the Price IDs for the Pro/Venue plan objects.
# The publishable key is exposed to the browser (NEXT_PUBLIC_) — it's how
# Stripe.js mounts the embedded checkout form in the control panel's Billing tab.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_VENUE=price_...
STRIPE_PRICE_ID_PRO_ANNUAL=price_...
STRIPE_PRICE_ID_VENUE_ANNUAL=price_...

# Email (Resend) — used to send the new-email verification link when a user
# changes their account email (frontend/app/api/account/email/route.ts).
# API key from the Resend dashboard. EMAIL_FROM must be a verified sender
# domain in Resend (e.g. "ScoreHub <noreply@scorehub.co.nz>").
RESEND_API_KEY=re_...
EMAIL_FROM=ScoreHub <noreply@scorehub.co.nz>

# Sentry (SA-28) — error tracking. Optional: unset in dev/self-hosted, no-op
# when absent. NEXT_PUBLIC_SENTRY_DSN is exposed to the browser (client-side
# errors); SENTRY_DSN covers server/edge runtimes. Same DSN value for both
# is fine — use the frontend project's DSN from the Sentry dashboard.
NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.us.sentry.io/0
SENTRY_DSN=https://...@o0.ingest.us.sentry.io/0
