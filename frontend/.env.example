NEXT_PUBLIC_RELAY_URL=https://your-relay.railway.app
NEXT_PUBLIC_CONTROL_SECRET=change-this-to-a-long-random-string

# Auth — generate NEXTAUTH_SECRET with: openssl rand -hex 32
NEXTAUTH_SECRET=change-this-to-a-long-random-string
NEXTAUTH_URL=https://scoringapp.samcorp.co.nz

# Users — comma-separated username:password pairs
# Example for two operators:
# AUTH_USERS=admin:secret123,operator2:pass456
AUTH_USERS=admin:changeme
