# Copy to .env and fill in before running docker compose up
BRIDGE_SECRET=change-this-to-a-long-random-string
CONTROL_SECRET=change-this-to-a-different-long-random-string

# For local Docker: leave as localhost
# For cloud Docker: set to the public URL of your relay container
NEXT_PUBLIC_RELAY_URL=http://localhost:4000
NEXT_PUBLIC_CONTROL_SECRET=change-this-to-a-different-long-random-string
