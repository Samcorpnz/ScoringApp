# Copy to .env and fill in before running docker compose up
BRIDGE_SECRET=change-this-to-a-long-random-string
CONTROL_SECRET=change-this-to-a-different-long-random-string

# For local Docker: leave as localhost
# For cloud Docker: set to the public URL of your relay container
NEXT_PUBLIC_RELAY_URL=http://localhost:4000
NEXT_PUBLIC_CONTROL_SECRET=change-this-to-a-different-long-random-string

# ── Bridge admin UI ─────────────────────────────────────────────────────────
# UI_PORT=4002          Admin UI port (default 4002 → http://localhost:4002)
# CD_AUTOSTART=true     Start the configured source automatically on boot

# ── ChampionData bridge sources (bridge package only) ───────────────────────
# Set CD_SOURCE to choose the data source:
#   saturn     Saturn/Vega serial port (default)
#   cd-json    Poll a ChampionData JSON URL with HTTP Basic Auth
#   cd-scrape  Puppeteer scraper for a ChampionData live web page
CD_SOURCE=saturn

# Path 1 — JSON feed with Basic Auth
# CD_URL=https://example.com/api/matchstats?matchid=12345
# CD_USERNAME=your-username
# CD_PASSWORD=your-password
# CD_POLL_MS=2000

# Path 2 — Web scraper (Puppeteer)
# CD_SCRAPE_URL=https://mc.championdata.com/CompetitionName/index.html?competitionid=XXXX&matchid=YYYY
# CD_POLL_MS=500
